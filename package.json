    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^24.1.1",
    "prettier": "^3.8.3",
    "vite": "^8.0.10",
    "vitest": "^1.6.1",
    "vue-eslint-parser": "^10.4.0"
